rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유저 문서 검증 헬퍼 함수
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // 요청 보낸 유저가 HQ(본사 관리자)인지 검증
    function isHQ() {
      return request.auth != null && getUserData().role == 'HQ';
    }

    // 요청 보낸 유저가 특정 파트너 코드를 가졌는지 검증
    function hasPartnerCode(partnerCode) {
      return request.auth != null && getUserData().partnerCode == partnerCode;
    }

    // 1. 주문 컬렉션 (Orders)
    match /orders/{orderId} {
      // 본사 관리자는 전체 조회 가능, MF 파트너는 자기 주문만 조회 가능
      allow read: if request.auth != null && (
        isHQ() || resource.data.partnerId == request.auth.uid
      );
      
      // 본사 관리자만 생성 및 모든 수정 가능
      allow create, update: if request.auth != null && isHQ();
      
      // 특정 문서 업로드 등 일부 필드는 파트너 본인도 수정(업로드) 가능하도록 허용
      allow update: if request.auth != null && 
        resource.data.partnerId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['documents', 'paymentStatus', 'receiptUrl']);
        
      // 주문 삭제는 절대 불가 (본사 포함 - 히스토리 무결성 보장)
      allow delete: if false;
    }

    // 2. 알림 컬렉션 (Notifications)
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }

    // 3. 상품 마스터 컬렉션 (Products)
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isHQ();
    }

    // 4. 파트너 정보 컬렉션 (Partners)
    match /partners/{partnerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isHQ();
    }

    // 5. 가입 초대장 컬렉션 (Invites)
    match /invites/{email} {
      // 가입 신청 단계에서 사전 등록 검증을 수행하기 위해 비인증 읽기 허용
      allow read: if true;
      // 본사 관리자만 초대장 생성 및 삭제 가능
      allow write: if request.auth != null && isHQ();
      // 가입 승인 성공 시 가입자 본인이 가입 완료 상태(USED)로 업데이트할 수 있도록 허용
      allow update: if true;
    }

    // 6. 회원 프로필 컬렉션 (Users)
    match /users/{uid} {
      // 로그인된 전체 사용자는 타인의 역할 확인 등을 위해 읽기 허용
      allow read: if request.auth != null;
      // 본사 관리자는 모든 회원 생성/수정 가능, 일반 사용자는 최초 가입 시점에 자기 본인 프로필만 생성/수정 가능
      allow create, update: if request.auth != null && (isHQ() || request.auth.uid == uid);
      // 회원 탈퇴 및 삭제는 본사 관리자만 처리 가능
      allow delete: if request.auth != null && isHQ();
    }

    // 7. 실시간 설정 및 공지사항 컬렉션 (Config)
    match /config/{configId} {
      // 로그인된 사용자만 읽기 허용
      allow read: if request.auth != null;
      // 본사 관리자(HQ)만 공지사항 등 설정 쓰기 허용
      allow write: if request.auth != null && isHQ();
    }
  }
}
